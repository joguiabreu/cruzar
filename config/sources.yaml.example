# Source allowlist (SPEC §Inputs). One entry per ACCOUNT. Copy to
# config/sources.yaml (gitignored) and fill in real values. Adding an account
# is a yaml edit, not a code change (AC7) — unless its format needs a new parser.
accounts:
  - institution: activobank        # selects parsers/<institution>.py
    name: Conta Simples
    account_match: activobank      # manual path: folder under data/inbox/<account_match>/
    source_type: manual
    account_type: checking
    currency: EUR
  - institution: moey
    name: Conta Moey
    account_match: moey            # files in data/inbox/moey/
    source_type: manual
    account_type: checking         # CONTA MOEY = à ordem (demand deposit)
    currency: EUR
  - institution: revolut
    name: Conta Revolut
    account_match: revolut         # files in data/inbox/revolut/
    source_type: manual
    account_type: checking         # E-Money / Conta Corrente = demand deposit
    currency: EUR
  - institution: interactivebrokers
    name: Conta Interactive Brokers
    account_match: interactivebrokers  # files in data/inbox/interactivebrokers/
    source_type: manual
    account_type: brokerage            # holdings + uninvested cash
    currency: EUR                      # base currency; holdings carry their own currency
    emits_cash_flows: false            # monthly summary has no per-deposit lines (ADR-14): Portfolio Δ shown gross
  - institution: degiro
    name: Conta Degiro
    account_match: degiro              # files in data/inbox/degiro/ (Portfolio + Account)
    source_type: manual
    account_type: brokerage
    currency: EUR
  - institution: aforronet
    name: Conta Aforro
    account_match: aforronet           # files in data/inbox/aforronet/ (Certificados de Aforro)
    source_type: manual
    account_type: brokerage            # bond-like savings certificates held as a position
    currency: EUR
    emits_cash_flows: false            # position snapshot, no movements ledger (ADR-14): Portfolio Δ shown gross
